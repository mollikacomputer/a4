// =====================================================
// 6. BOOKINGS
// =====================================================

model Booking {
  id           String        @id @default(uuid())
  customerId   String        @map("customer_id")
  technicianId String        @map("technician_id")
  serviceId    String        @map("service_id")
  slotId       String?       @unique @map("slot_id")
  status       BookingStatus @default(PENDING)
  bookingDate  DateTime      @map("booking_date") @db.Date
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  customer   User              @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  technician User              @relation("TechnicianBookings", fields: [technicianId], references: [id], onDelete: Cascade)
  service    Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  slot       AvailabilitySlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)

  payment Payment?
  review  Review?

  @@index([customerId])
  @@index([technicianId])
  @@index([status])
  @@map("bookings")
}
